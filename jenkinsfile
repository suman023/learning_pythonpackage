pipeline {
    agent any
    environment {
        PACKAGE_NAME = "my_package"
        PYTHON       = "python3"
        VENV_DIR     = "venv"
        SONAR_TOKEN  = "5aeea4d68a3d02e89125868c25c917fb3d821fb9"
    }
    stages {
        stage('Checkout') {
            steps {
                echo '📥 Checking out source code...'
                checkout scm
            }
        }
        stage('Setup Python Environment') {
            steps {
                echo '🐍 Creating virtual environment...'
                sh """
                    ${PYTHON} -m venv ${VENV_DIR}
                    . ${VENV_DIR}/bin/activate
                    pip install --upgrade pip
                    pip install build
                    if [ -f requirements.txt ]; then pip install -r requirements.txt; fi
                """
            }
        }
        stage('Build WHL Package') {
            steps {
                echo '📦 Building wheel package...'
                sh """
                    . ${VENV_DIR}/bin/activate
                    python3 -m build
                """
            }
        }
        stage('Archive Artifacts') {
            steps {
                echo '🗄️ Archiving dist artifacts...'
                archiveArtifacts artifacts: 'dist/*.whl, dist/*.tar.gz',
                                 fingerprint: true,
                                 allowEmptyArchive: false
            }
        }
        stage('Analyzing Code Quality') {
            steps {
                echo '🔍 Analyzing code quality with SonarQube...'
                sh """/opt/sonar-scanner/bin/sonar-scanner \
                    -Dsonar.projectKey=suman023_learning_pythonpackage \
                    -Dsonar.organization=suman023 \
                    -Dsonar.sources=my_package \
                    -Dsonar.host.url=https://sonarcloud.io \
                    -Dsonar.login=${SONAR_TOKEN} \
                    -Dsonar.qualitygate.wait=false \
                    -Dsonar.qualitygate.timeout=300
                """
            }
        }
    }
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed. Check logs above.'
        }
        always {
            echo '🧹 Cleaning up workspace...'
            cleanWs()
        }
    }
}
